generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String   @id @default(cuid()) // String ID for OAuth compatibility
  email               String   @unique
  password            String?  // optional for OAuth users
  username            String?  @unique
  authProvider        String   @default("credentials") // "google" | "credentials"
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  name                String?
  image               String?

  quizUsage           Int      @default(0)
  lastQuizAt          DateTime?
  lastQuizAdResetAt   DateTime?
  quizAdResetCount    Int      @default(0)
  quizAdResetWindowAt DateTime?
  freeQuizPoints      Int      @default(100)
  freeQuizPointsMax   Int      @default(100)
  freeQuizPointsRechargeAt DateTime?
  freeLessonPlanPoints Int     @default(100)
  freeLessonPlanPointsMax Int  @default(100)
  freeLessonPlanPointsRechargeAt DateTime?
  subscriptionEnd     DateTime?
  subscriptionPlan    String?
  subscriptionStart   DateTime?
  subscriptionStatus  String?
  stripeCustomerId    String?
  paypalCustomerId    String?
  adaptiveLearning    Boolean? @default(false)
  aiDifficulty        String?
  liteMode            Boolean  @default(false)

  lessonPlanUsage     Int  @default(0)  
  lastLessonPlanAt    DateTime?
  lessonMaterialUploadUsage Int @default(0)
  lastLessonMaterialUploadAt DateTime?
  lastActiveAt        DateTime?
  marketingOptIn      Boolean  @default(true)
  marketingUnsubscribedAt DateTime?

  quizzes             Quiz[]
  resetTokens         PasswordResetToken[]
  policyAcceptances   UserPolicyAcceptance[]
  signupOtps         SignupOtp[]
  paypalSubscriptions PayPalSubscription[]
  gcashPayments      GCashPayment[]
  lessonPlans        LessonPlan[]
  lessonPlanExports  LessonPlanExport[]
  winbackEmails      WinbackEmailLog[]
  loginSessions      UserLoginSession[]
  asyncGenerationJobs AsyncGenerationJob[]
  classes            Class[]
  assignments        Assignment[]
  ownedOrganizations Organization[] @relation("OrganizationOwner")
  organizationMemberships OrganizationMember[]
  organizationInvitationsSent OrganizationInvitation[] @relation("OrganizationInvitationSender")
  organizationSubscriptions OrganizationSubscription[] @relation("OrganizationBillingUser")
}

model Organization {
  id            String   @id @default(cuid())
  name          String
  slug          String?  @unique
  billingEmail  String?
  status        String   @default("active")
  tier          String   @default("organization")
  seatLimit     Int?
  ownerUserId   String
  ownerUser     User     @relation("OrganizationOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  members       OrganizationMember[]
  invitations   OrganizationInvitation[]
  subscriptions OrganizationSubscription[]
  quizzes       Quiz[]
  lessonPlans   LessonPlan[]
  classes       Class[]
  assignments   Assignment[]

  @@index([ownerUserId, createdAt])
  @@index([status, createdAt])
}

model OrganizationMember {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String   @default("teacher")
  status         String   @default("active")
  joinedAt       DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, userId])
  @@index([userId, status])
  @@index([organizationId, role])
}

model OrganizationInvitation {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           String   @default("teacher")
  status         String   @default("pending")
  token          String   @unique
  invitedByUserId String?
  invitedByUser  User?    @relation("OrganizationInvitationSender", fields: [invitedByUserId], references: [id], onDelete: SetNull)
  expiresAt      DateTime?
  acceptedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId, status])
  @@index([email, status])
}

model OrganizationSubscription {
  id                    String   @id @default(cuid())
  organizationId        String
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  billingUserId         String?
  billingUser           User?    @relation("OrganizationBillingUser", fields: [billingUserId], references: [id], onDelete: SetNull)
  provider              String?
  providerSubscriptionId String? @unique
  plan                  String
  status                String
  seatCount             Int?
  billingEmail          String?
  currentPeriodStart    DateTime?
  currentPeriodEnd      DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([organizationId, status])
  @@index([billingUserId, createdAt])
}

model UserPolicyAcceptance {
  id         Int     @id @default(autoincrement())
  user       User    @relation(fields: [userId], references: [id])
  userId     String
  policyType String   // e.g., "terms", "privacy"
  accepted   Boolean  @default(false)
  acceptedAt DateTime @default(now())

  @@unique([userId, policyType])
}

model Quiz {
  id           Int        @id @default(autoincrement())
  title        String
  instructions String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  organizationId String?
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  questions    Question[]
  attempts     StudentQuizAttempt[]
  takeLocks    StudentQuizTake[]
  shareSettings QuizShareSettings?
  assignments  Assignment[]

  @@index([organizationId, createdAt])
}

model Question {
  id          Int      @id @default(autoincrement())
  question    String
  options     String[]
  answer      String
  explanation String?
  hint        String?
  quizId      Int
  quiz        Quiz     @relation(fields: [quizId], references: [id])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model SignupOtp {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String
  passwordHash String
  otpHash      String
  expiresAt    DateTime
  attempts     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([expiresAt])
}

model PayPalSubscription {
  id               String   @id @default(cuid())
  subscriptionId   String   @unique
  planId           String
  planType         String
  status           String
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  startTime        DateTime
  nextBillingTime  DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model GCashPayment {
  id         String   @id @default(cuid())
  checkoutId String   @unique
  paymentId  String?
  amount     Int
  currency   String   @default("PHP")
  planType   String
  status     String
  metadata   Json?
  paidAt     DateTime?
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model PublicUsage {
  id        String    @id
  count     Int       @default(0)
  resetAt   DateTime?
  updatedAt DateTime  @updatedAt
  createdAt DateTime  @default(now())
  ip        String?
}

model BlogPost {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  excerpt         String
  content         String   // markdown or HTML
  metaTitle       String
  metaDescription String
  published       Boolean  @default(true)
  featuredImage   String?  // Optional image URL
  authorName      String?  // Optional
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model LessonPlan {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String?
  organization  Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  title         String
  topic         String
  subject       String
  grade         String
  duration      String
  days          Int
  minutesPerDay Int
  data          Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  exports       LessonPlanExport[]
  assignments   Assignment[]

  @@index([userId, createdAt])
  @@index([organizationId, createdAt])
}

model Class {
  id         String        @id @default(cuid())
  userId     String
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String?
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  name       String
  subject    String?
  gradeLevel String?
  section    String?
  schoolYear String?
  archived   Boolean       @default(false)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  students   ClassStudent[]
  assignments Assignment[]

  @@index([userId, createdAt])
  @@index([userId, archived])
  @@index([organizationId, createdAt])
}

model ClassStudent {
  id            String   @id @default(cuid())
  classId        String
  class          Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  studentName    String
  studentEmail   String?
  studentNumber  String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([classId, createdAt])
  @@index([classId, studentEmail])
}

model Assignment {
  id           String              @id @default(cuid())
  userId       String
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String?
  organization Organization?       @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  classId      String
  class        Class               @relation(fields: [classId], references: [id], onDelete: Cascade)
  quizId       Int?
  quiz         Quiz?               @relation(fields: [quizId], references: [id], onDelete: SetNull)
  lessonPlanId String?
  lessonPlan   LessonPlan?         @relation(fields: [lessonPlanId], references: [id], onDelete: SetNull)
  title        String
  instructions String?
  status       String              @default("draft")
  availableFrom DateTime?
  dueAt        DateTime?
  closedAt     DateTime?
  shareToken   String?             @unique
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  attempts     StudentQuizAttempt[]

  @@index([userId, createdAt])
  @@index([organizationId, createdAt])
  @@index([classId, status])
  @@index([quizId])
  @@index([lessonPlanId])
}

model LessonPlanExport {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonPlanId String?
  lessonPlan   LessonPlan? @relation(fields: [lessonPlanId], references: [id], onDelete: SetNull)
  format      String
  status      String    @default("queued") // queued | processing | completed | failed
  inputHash   String
  input       Json
  resultData  Bytes?
  mimeType    String?
  fileName    String?
  error       String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([lessonPlanId])
  @@unique([userId, format, inputHash])
}

model Document {
  id         String   @id @default(cuid())
  namespace  String
  sourceUrl  String?
  title      String?
  sourceType String?  // "web" | "pdf" | "pptx" | "docx" | "text"
  chunkIndex Int
  content    String
  embedding  Unsupported("vector")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([namespace])
  @@index([sourceUrl])
}

model SemanticCache {
  id        String   @id @default(cuid())
  namespace String
  prompt    String
  response  String
  embedding Unsupported("vector")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([namespace])
}

model GenerationEvent {
  id        String   @id @default(cuid())
  userId    String?
  eventType String
  feature   String?
  status    String
  plan      String?
  latencyMs Int?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([eventType, createdAt])
  @@index([userId, createdAt])
}

model WinbackEmailLog {
  id           String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  milestoneDay  Int
  sentAt        DateTime @default(now())
  createdAt     DateTime @default(now())

  @@unique([userId, milestoneDay])
  @@index([milestoneDay, sentAt])
  @@index([userId, sentAt])
}

model UserLoginSession {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId  String   @unique
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())
  revokedAt  DateTime?

  @@index([userId, lastSeenAt])
  @@index([userId, revokedAt])
}

model StudentQuizAttempt {
  id             String   @id @default(cuid())
  quizId         Int
  quiz           Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  assignmentId   String?
  assignment     Assignment? @relation(fields: [assignmentId], references: [id], onDelete: SetNull)
  studentName    String?
  studentEmail   String?
  scorePercent   Int
  correctAnswers Int
  totalQuestions Int
  result         Json
  ip             String?
  userAgent      String?
  submittedAt    DateTime @default(now())
  createdAt      DateTime @default(now())

  @@index([quizId, submittedAt])
  @@index([assignmentId, submittedAt])
  @@index([studentEmail, submittedAt])
  @@unique([quizId, studentEmail, assignmentId])
}

model QuizShareSettings {
  id        String   @id @default(cuid())
  quizId    Int      @unique
  quiz      Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  isOpen    Boolean  @default(true)
  expiresAt DateTime?
  assessmentDurationMinutes Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([quizId, isOpen])
  @@index([expiresAt])
}

model StudentQuizTake {
  id            String   @id @default(cuid())
  quizId        Int
  quiz          Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  takeSessionId String
  submittedAt   DateTime @default(now())
  createdAt     DateTime @default(now())

  @@unique([quizId, takeSessionId])
  @@index([quizId, submittedAt])
}

model AsyncGenerationJob {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String
  status      String   @default("queued") // queued | processing | completed | failed
  request     Json
  result      Json?
  error       String?
  attemptCount Int     @default(0)
  requestId   String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([type, createdAt])
}
